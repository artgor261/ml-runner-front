# Base URL of the backend API. Leave empty to use the dev proxy (vite.config.ts).
VITE_API_BASE_URL=

# Target used by the Vite dev-server proxy for /api requests.
VITE_API_PROXY_TARGET=http://localhost:8000

# Directory where the backend stores dataset parquet files. The dev server
# serves these (read-only, .parquet only) so the UI can preview dataset rows.
# Defaults to ~/ml-runner-backend/datasets.
VITE_DATASETS_DIR=
